{
  "name": "shiva_assessment_demo_appium",
  "version": "1.0.0",
  "description": "Enterprise-grade Appium + WebdriverIO E2E framework for Sauce Labs My Demo App (Android)",
  "author": "Shiva Assessment",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18 <26"
  },
  "scripts": {
    "pretest": "bash scripts/ensure-emulator.sh",
    "appium:doctor": "appium driver list --installed",
    "test": "wdio run ./wdio.conf.ts",
    "test:smoke": "wdio run ./wdio.conf.ts --mochaOpts.grep @smoke",
    "test:auth": "wdio run ./wdio.conf.ts --spec ./tests/auth/**/*.spec.ts",
    "test:catalog": "wdio run ./wdio.conf.ts --spec ./tests/catalog/**/*.spec.ts",
    "test:cart": "wdio run ./wdio.conf.ts --spec ./tests/cart/**/*.spec.ts",
    "test:e2e": "wdio run ./wdio.conf.ts --spec ./tests/e2e/**/*.spec.ts",
    "report:allure": "npx allure generate allure-results --clean -o allure-report && npx allure open allure-report",
    "lint:types": "tsc --noEmit",
    "clean": "rm -rf allure-results allure-report reports test-results",
    "prepare:apk": "mkdir -p apps && cp ../my-demo-app-android/app/build/outputs/apk/debug/app-debug.apk apps/mydemoapp.apk"
  },
  "keywords": [
    "appium",
    "webdriverio",
    "android",
    "e2e",
    "qa",
    "sauce-labs",
    "typescript"
  ],
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.43",
    "@wdio/allure-reporter": "^9.29.1",
    "@wdio/appium-service": "^9.29.1",
    "@wdio/cli": "^9.29.1",
    "@wdio/junit-reporter": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "allure-commandline": "^2.43.0",
    "appium": "^2.19.0",
    "appium-uiautomator2-driver": "^3.9.6",
    "dotenv": "^16.6.1",
    "expect-webdriverio": "^5.7.0",
    "mocha": "^11.7.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "webdriverio": "^9.29.1"
  }
}
